# ============================================================
#  Variables Homepage — À copier en .env dans /opt/docker/homepage/
#  NE JAMAIS committer le .env sur Git !
# ============================================================

# --- Jellyfin ---
# Paramètres > Clés API > Nouvelle clé API
HOMEPAGE_VAR_JELLYFIN_API=your_jellyfin_api_key

# --- Jellyseerr ---
# Paramètres > Général > Clé API
HOMEPAGE_VAR_JELLYSEERR_API=your_jellyseerr_api_key

# --- Sonarr ---
# Paramètres > Général > Clé API
HOMEPAGE_VAR_SONARR_API=your_sonarr_api_key

# --- Radarr ---
# Paramètres > Général > Clé API
HOMEPAGE_VAR_RADARR_API=your_radarr_api_key

# --- Prowlarr ---
# Paramètres > Général > Clé API
HOMEPAGE_VAR_PROWLARR_API=your_prowlarr_api_key

# --- Bazarr ---
# Paramètres > Général > Clé API
HOMEPAGE_VAR_BAZARR_API=your_bazarr_api_key

# --- Autobrr ---
# Paramètres > Clé API
HOMEPAGE_VAR_AUTOBRR_API=your_autobrr_api_key

# --- qBittorrent ---
HOMEPAGE_VAR_QB_USER=your_qbittorrent_username
HOMEPAGE_VAR_QB_PASS=your_qbittorrent_password

# --- AdGuard Home ---
HOMEPAGE_VAR_ADGUARD_USER=your_adguard_username
HOMEPAGE_VAR_ADGUARD_PASS=your_adguard_password
