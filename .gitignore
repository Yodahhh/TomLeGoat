# Secrets — ne jamais committer !
.env
*.env

# Certificats TLS Let's Encrypt
traefik/acme.json

# Données de configuration des services (contiennent clés API, DB, etc.)
jellyfin/
jellyseerr/
sonarr/
radarr/
prowlarr/
bazarr/
qbittorrent/
homeassistant/
adguard/
