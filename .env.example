# ============================================================
#  Variables d'environnement — Homelab Docker Stack
#  Copier ce fichier en .env et remplir les valeurs
#  NE JAMAIS committer le fichier .env sur Git !
# ============================================================

# --- Traefik / DNS Challenge ---
# Token API de ton fournisseur DNS pour les certificats Let's Encrypt (ACME)
# Infomaniak : https://manager.infomaniak.com/v3/ng/profile/api
INFOMANIAK_ACCESS_TOKEN=your_infomaniak_token_here

# --- WireGuard VPN (Gluetun) ---
# Adresse IP publique de ton VPS (endpoint WireGuard)
WIREGUARD_ENDPOINT_IP=your_vps_ip_here
# Port d'écoute WireGuard sur le VPS
WIREGUARD_ENDPOINT_PORT=51820
# Clé privée WireGuard du client (générée avec wg genkey)
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
# Clé publique WireGuard du serveur VPS (dans /etc/wireguard/wg0.conf sur le VPS)
WIREGUARD_PUBLIC_KEY=your_wireguard_server_public_key_here
# Adresse IP attribuée au client dans le réseau WireGuard
WIREGUARD_ADDRESSES=10.100.0.2/24

# --- YGGTorrent — Compte 1 (IP box internet) ---
YGG_USERNAME_1=your_ygg_username_1
YGG_PASSWORD_1=your_ygg_password_1

# --- YGGTorrent — Compte 2 (IP VPS via Gluetun) ---
YGG_USERNAME_2=your_ygg_username_2
YGG_PASSWORD_2=your_ygg_password_2
